rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /appointments/{appointment} {
      allow read: if isAuthenticated();
      allow create: if isValidAppointment();
      allow update: if isAuthenticated();
      allow delete: if isOwner();
    }

    match /{document=**}{
      allow read, write: if false
    }

  }

  function isAuthenticated(){
    return request.auth != null;
  }

  function isValidAppointment(){
    // email of incoming doc should match the authenticated user
    return request.resource.data.author == request.auth.token.email;
  }

  function isOwner() {
    return resource.data.author == request.auth.token.email;
  }
}
