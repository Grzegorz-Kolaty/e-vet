rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isCreateOwner() {
      return request.auth != null
        && request.resource.data.vetId == request.auth.uid;
    }

    function isVetInClinic(clinicId) {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/clinics/$(clinicId))
        && request.auth.uid in get(/databases/$(database)/documents/clinics/$(clinicId)).data.members;
    }

    // ---------------- CLINICS ----------------
    match /clinics/{clinicId} {
      allow read, write: if isAuthenticated();
    }

    // ---------------- APPOINTMENTS ----------------
    match /appointments/{appointmentId} {
      allow read: if isAuthenticated();
      allow create: if isCreateOwner();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // ---------------- USERS ----------------
    match /users/{userId} {
      allow read, write: if isAuthenticated();
    }

    // ---------------- VETS ----------------
    match /vets/{vetId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated()
        && request.auth.uid == vetId;
    }

    // ---------------- METADATA (NOWOŚĆ) ----------------
    match /metadata/{documentId} {
      allow read, write: if isAuthenticated();
    }

  }
}
